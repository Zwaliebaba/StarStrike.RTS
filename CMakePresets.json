{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                    "type": "FILEPATH"
                }
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug (MSVC)",
            "inherits": "base",
            "binaryDir": "${sourceDir}/out/build/x64-debug",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "VCPKG_TARGET_TRIPLET": "x64-windows",
                "ENABLE_PROFILING": "ON",
                "ENABLE_DEBUG_UI": "ON",
                "ENABLE_VALIDATION_LAYERS": "ON"
            }
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release (MSVC)",
            "inherits": "base",
            "binaryDir": "${sourceDir}/out/build/x64-release",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "VCPKG_TARGET_TRIPLET": "x64-windows",
                "ENABLE_PROFILING": "OFF",
                "ENABLE_VALIDATION_LAYERS": "OFF"
            }
        },
        {
            "name": "linux-server",
            "displayName": "Linux Server (Headless)",
            "inherits": "base",
            "binaryDir": "${sourceDir}/out/build/linux-server",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_COMPILER": "g++",
                "VCPKG_TARGET_TRIPLET": "x64-linux",
                "BuildServerOnly": "ON",
                "ENABLE_PROFILING": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "x64-debug-build",
            "displayName": "x64 Debug Build",
            "configurePreset": "x64-debug",
            "jobs": 0
        },
        {
            "name": "x64-release-build",
            "displayName": "x64 Release Build",
            "configurePreset": "x64-release",
            "jobs": 0
        }
    ],
    "testPresets": [
        {
            "name": "x64-debug-test",
            "configurePreset": "x64-debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
